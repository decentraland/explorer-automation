# Copy this file to `.env` and fill in real values.
# `.env` is gitignored — never commit credentials.

# IMAP server (Decentraland uses Google Workspace → imap.gmail.com)
EXPLORER_IMAP_HOST=imap.gmail.com
EXPLORER_IMAP_PORT=993

# Mailbox account that receives the OTP emails.
# The login test uses plus-addressing (user+<hash>@domain) so any +alias
# delivers to this same mailbox.
EXPLORER_IMAP_USER=your-account@example.com

# Google App Password (NOT your regular password).
# Generate at: https://myaccount.google.com/apppasswords
EXPLORER_IMAP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Sender address of the OTP email — used to filter the inbox.
# Decentraland delegates email auth to Thirdweb.
EXPLORER_IMAP_FROM_USER=no-reply@thirdweb.com

# Optional: comma-separated list of alternate BASE email addresses (no '+hash') to fall
# back to when the primary address hits Thirdweb's rate limit (429). The test code adds
# a fresh '+hash' suffix to each on use, so every fallback attempt is a unique signup
# in its own per-address rate-limit bucket. All listed addresses MUST route to the inbox
# at EXPLORER_IMAP_USER (e.g. domain aliases that forward to it, or sub-aliases on the
# same Workspace) since we read the OTPs back via a single IMAP connection.
EXPLORER_ALTERNATE_EMAILS=email1,email2,email3