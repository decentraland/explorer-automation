node_modules/
packages/*/bin/
packages/*/.dcl-cache/
packages/*/dist/
# main.crdt is regenerated by sdk-commands on every scene start — never commit it.
packages/*/main.crdt
# _host gets its assets/ rewritten every time VisualHost.Load mirrors a test scene's
# assets into it; never commit anything generated under _host beyond src/.
packages/_host/assets/
*.log
.DS_Store
