
# Disable npm's auto-save behaviour for this workspace.
#
# Why: scene packages depend on `@dcl/js-runtime@latest` and an SDK tarball
# that transitively pins a SHA-tagged prerelease of js-runtime. When npm
# resolves the dep tree it picks that prerelease, and (via implicit save
# during install or via sdk-commands' bootstrap) writes the resolved
# version back into `package.json`. The prerelease eventually gets evicted
# from the npm registry, and the next install fails with ETARGET.
#
# `save=false` makes every install a transient operation: npm resolves the
# tree at install time but never modifies `package.json` or `package-lock.json`.
# `"latest"` stays literal and re-resolves fresh on every install.
#
# Trade-off: lockfiles in this workspace are not authoritative — assume the
# tree is rebuilt fresh per install. Acceptable here because scene builds
# are deterministic outputs (bundles), not long-lived libraries.
save=false
fund=false
audit=false
