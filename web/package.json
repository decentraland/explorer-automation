{
  "name": "decentraland-web-automation",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Playwright UI automation for the Decentraland web dapp and the cross-platform handoff into the desktop client.",
  "scripts": {
    "test": "playwright test --grep @web",
    "test:headed": "playwright test --grep @web --headed",
    "test:ui": "playwright test --ui",
    "test:webgpu": "playwright test --project webgpu",
    "test:marketplace": "npm run test:marketplace:offchain && npm run test:marketplace:onchain",
    "test:marketplace:offchain": "playwright test --project=marketplace",
    "test:marketplace:onchain": "playwright test --project=marketplace-onchain --workers=1",
    "test:auth:onchain": "playwright test --project=auth-onchain --workers=1",
    "test:all": "playwright test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "report": "playwright show-report",
    "postinstall": "playwright install chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@synthetixio/ethereum-wallet-mock": "^0.0.14",
    "@synthetixio/synpress": "^4.1.2",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-playwright": "^1.6.0",
    "prettier": "^3.3.0",
    "typescript": "^5.6.0",
    "viem": "^2.48.8"
  },
  "dependencies": {
    "@types/mailparser": "^3.4.6",
    "dotenv": "^16.4.0",
    "imapflow": "^1.0.0",
    "mailparser": "^3.9.8"
  },
  "engines": {
    "node": ">=20"
  }
}
